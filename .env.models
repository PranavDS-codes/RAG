# --- MODEL ROUTING CONFIGURATION (.env.models) ---
# We now route everything through NVIDIA API to avoid Groq rate limits.

PREMISE_PROVIDER=nvidia
PREMISE_MODEL=openai/gpt-oss-120b

QUERY_PROVIDER=nvidia
QUERY_MODEL=openai/gpt-oss-120b

AUDIT_PROVIDER=nvidia
AUDIT_MODEL=openai/gpt-oss-120b

VERIFY_PROVIDER=nvidia
VERIFY_MODEL=openai/gpt-oss-120b

REFINE_PROVIDER=nvidia
REFINE_MODEL=openai/gpt-oss-120b

SCOUT_PROVIDER=nvidia
SCOUT_MODEL=openai/gpt-oss-120b

SYNTHESIZE_PROVIDER=nvidia
SYNTHESIZE_MODEL=openai/gpt-oss-120b   

VECTOR_CURATOR_PROVIDER=nvidia
VECTOR_CURATOR_MODEL=openai/gpt-oss-120b

GRAPH_CURATOR_PROVIDER=nvidia
GRAPH_CURATOR_MODEL=openai/gpt-oss-120b
